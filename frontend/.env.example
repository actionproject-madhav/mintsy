# Copy to .env.local for local dev

# Backend API (must match CORS allowlist — same origin as FRONTEND_URL on backend)
# Match backend PORT (5001 recommended on macOS — avoid conflict with AirPlay on 5000)
VITE_API_URL=http://localhost:5001/api

# Google OAuth Web Client ID (same as backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=
