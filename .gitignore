.DS_Store
Thumbs.db

# Logs & caches
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.cache/

# IDE (keep shared VS Code recommendations if you add them)
.idea/
.vscode/*
!.vscode/extensions.json

# Test / coverage
coverage/
.nyc_output/

# Deploy / tooling (may reference project links; harmless to ignore locally)
.vercel
.turbo
