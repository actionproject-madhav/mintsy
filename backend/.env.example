# Copy to .env and fill in. Never commit .env.

NODE_ENV=development
# On macOS, port 5000 is often used by AirPlay Receiver — use 5001 if /health returns 403 from "AirTunes".
PORT=5001

# --- MongoDB (required) ---
# Atlas: Database → Connect → Drivers → copy the SRV string into your local .env only.
# Local dev (no Atlas): mongodb://127.0.0.1:27017/mintsy
MONGODB_URI=

# --- Auth (required) ---
# Generate: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRE=7d

# Google OAuth — same Client ID as frontend VITE_GOOGLE_CLIENT_ID (Web client)
GOOGLE_CLIENT_ID=

# --- URLs (required for browser clients) ---
FRONTEND_URL=http://localhost:5173
# Optional: multiple dev/prod origins, comma-separated (overrides FRONTEND_URL for CORS allowlist)
# Dev: localhost and 127.0.0.1 on the same port are auto-added as a pair so either URL works.
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# --- MetalpriceAPI (optional — spot quotes on /api/prices/spot) ---
# METALS_API_KEY=

# --- Alpha Vantage (optional — gold/silver history chart on /api/prices/history) ---
# Either name works (dotenv is case-sensitive for the key name).
# ALPHA_VANTAGE_API_KEY=
# alpha_vantage_api_key=

# --- Stripe (optional — leave empty until you need featured listing checkout) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_FEATURED_LISTING_PRICE_ID=
